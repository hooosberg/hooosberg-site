---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductTermsOfService from "../../components/ProductTermsOfService.astro";
import { products, type Product } from "../../data/products";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

type Props = {
  product: Product;
};

const { product } = Astro.props;
---

<BaseLayout
  title={`${product.displayName} Terms of Service | 湖森堡AI_hooosberg`}
  description={`${product.displayName} terms of service.`}
  canonicalPath={`/terms/${product.slug}`}
  image={product.icon ?? "/brand/hooosberg-ai-icon.png"}
>
  <ProductTermsOfService product={product} />
</BaseLayout>
