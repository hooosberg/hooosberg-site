---
import { ArrowRight, ExternalLink, Mail, Search } from "@lucide/astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { socialLinks } from "../../data/products";

type CountryCode = "us" | "cn" | "uk" | "au" | "ca" | "fr" | "global";

type ToolItem = {
  name: string;
  description: string;
  url: string;
  country: CountryCode;
  icon?: string;
  tags: string[];
  badge?: string;
};

type ToolGroup = {
  id: string;
  title: string;
  shortLabel: string;
  summary: string;
  items: ToolItem[];
  moreTarget?: string;
  moreLabel?: string;
};

type AlternativePair = {
  id: string;
  category: string;
  source: ToolItem;
  alternatives: ToolItem[];
  reason: string;
  bestFor: string[];
};

const countryMeta: Record<CountryCode, { flag: string; name: string; access: string; tone: "limited" | "easy" | "neutral" }> = {
  us: { flag: "🇺🇸", name: "美国", access: "国内可能受限", tone: "limited" },
  cn: { flag: "🇨🇳", name: "中国", access: "国内可直接尝试", tone: "easy" },
  uk: { flag: "🇬🇧", name: "英国", access: "访问视地区而定", tone: "neutral" },
  au: { flag: "🇦🇺", name: "澳大利亚", access: "访问视地区而定", tone: "neutral" },
  ca: { flag: "🇨🇦", name: "加拿大", access: "访问视地区而定", tone: "neutral" },
  fr: { flag: "🇫🇷", name: "法国", access: "访问视地区而定", tone: "neutral" },
  global: { flag: "🌐", name: "全球/开源", access: "按部署方式而定", tone: "neutral" },
};

const icon = {
  openai: "/icons/ai-tools/openai-codex.svg",
  claude: "/icons/ai-tools/claude-code.svg",
  gemini: "/icons/ai-tools/gemini.svg",
  antigravity: "/icons/ai-tools/antigravity.svg",
  copilot: "/icons/ai-tools/copilot.svg",
  cursor: "/icons/ai-tools/cursor.svg",
  windsurf: "/icons/ai-tools/windsurf.svg",
  trae: "/icons/ai-tools/trae.svg",
  cline: "/icons/ai-tools/cline.svg",
  roo: "/icons/ai-tools/roo-code.svg",
  opencode: "/icons/ai-tools/opencode.svg",
  kiro: "/icons/ai-tools/kiro.svg",
};

const tool = (item: ToolItem): ToolItem => item;

const chatgpt = tool({
  name: "ChatGPT",
  description: "OpenAI 的通用 AI 助手，也是 Deep Research、Canvas、Projects、语音、图像和 agent 能力的主入口。",
  url: "https://chatgpt.com/",
  country: "us",
  icon: icon.openai,
  tags: ["通用", "多模态", "全球热门"],
  badge: "必用",
});

const claude = tool({
  name: "Claude",
  description: "Anthropic 的通用助手，长文本、写作、代码理解和复杂任务表现稳定。",
  url: "https://claude.ai/",
  country: "us",
  icon: icon.claude,
  tags: ["写作", "长上下文", "代码"],
  badge: "必用",
});

const gemini = tool({
  name: "Gemini",
  description: "Google 生态里的 AI 助手主应用，适合多模态、搜索联动和日常资料处理。",
  url: "https://gemini.google.com/app",
  country: "us",
  icon: icon.gemini,
  tags: ["Google", "多模态", "搜索"],
  badge: "必用",
});

const codex = tool({
  name: "OpenAI Codex",
  description: "OpenAI 的编程 agent，适合仓库级代码任务、修复、构建和审查。",
  url: "https://chatgpt.com/codex/",
  country: "us",
  icon: icon.openai,
  tags: ["编程", "Agent", "OpenAI"],
  badge: "开发者",
});

const openaiApiPlatform = tool({
  name: "OpenAI API Platform",
  description: "OpenAI API、模型、开发文档和应用构建入口，适合把 ChatGPT、Codex 和 agent 能力接进产品。",
  url: "https://platform.openai.com/",
  country: "us",
  icon: icon.openai,
  tags: ["API", "模型", "开发"],
  badge: "开发者",
});

const claudeCode = tool({
  name: "Claude Code",
  description: "Anthropic 的终端编程 agent，适合项目理解、重构、测试和 Git 工作流。",
  url: "https://claude.ai/code",
  country: "us",
  icon: icon.claude,
  tags: ["编程", "终端", "Agent"],
  badge: "开发者",
});

const claudeCowork = tool({
  name: "Claude Cowork",
  description: "Anthropic 面向知识工作的 agentic AI，可在桌面环境里处理文件、应用和多步骤交付任务。",
  url: "https://www.anthropic.com/product/claude-cowork",
  country: "us",
  icon: icon.claude,
  tags: ["团队", "协作", "工作流"],
});

const notebookLm = tool({
  name: "NotebookLM",
  description: "Google 的资料阅读和研究工具，适合基于材料问答、摘要、音频概览和学习资料整理。",
  url: "https://notebooklm.google/",
  country: "us",
  icon: icon.gemini,
  tags: ["资料", "笔记", "研究"],
});

const googleAiStudio = tool({
  name: "Google AI Studio",
  description: "Gemini API、模型实验和应用原型入口，适合快速试模型、写提示词和做开发者 demo。",
  url: "https://aistudio.google.com/",
  country: "us",
  icon: icon.gemini,
  tags: ["Gemini", "API", "开发"],
  badge: "开发者",
});

const googleAntigravity = tool({
  name: "Google Antigravity",
  description: "Google 的 agent-first 开发平台，适合用 Gemini 驱动多 agent 规划、执行和验证代码任务。",
  url: "https://antigravity.google/",
  country: "us",
  icon: icon.antigravity,
  tags: ["IDE", "Agent", "Google"],
});

const jules = tool({
  name: "Jules",
  description: "Google 的异步编程 agent，适合把代码任务交给云端 agent 后再回来审查结果。",
  url: "https://jules.google.com/",
  country: "us",
  icon: icon.gemini,
  tags: ["编程", "异步", "Agent"],
});

const kimi = tool({
  name: "Kimi",
  description: "月之暗面推出的 AI 助手，长文档、搜索、PPT、表格和 agent 能力都值得关注。",
  url: "https://www.kimi.com/",
  country: "cn",
  tags: ["长文档", "搜索", "Agent"],
  badge: "国产",
});

const doubao = tool({
  name: "豆包",
  description: "字节跳动旗下大众化 AI 助手，覆盖聊天、图片、音视频和移动端场景。",
  url: "https://www.doubao.com/",
  country: "cn",
  tags: ["多模态", "移动端", "字节"],
  badge: "国产",
});

const qwen = tool({
  name: "通义千问",
  description: "阿里云通义体系的对话和模型入口，适合中文、办公、代码和开发平台联动。",
  url: "https://chat.qwen.ai/",
  country: "cn",
  tags: ["Qwen", "模型", "中文"],
  badge: "国产",
});

const deepseek = tool({
  name: "DeepSeek",
  description: "国产高关注度模型与对话入口，适合推理、代码、中文问答和低成本 API。",
  url: "https://chat.deepseek.com/",
  country: "cn",
  tags: ["推理", "代码", "模型"],
  badge: "国产",
});

const trae = tool({
  name: "TRAE",
  description: "字节跳动推出的 AI 编程工具，适合 IDE、Web 和移动端开发流程。",
  url: "https://www.trae.ai/",
  country: "cn",
  icon: icon.trae,
  tags: ["IDE", "Agent", "字节"],
  badge: "国产",
});

const groups: ToolGroup[] = [
  {
    id: "top",
    title: "顶级产品榜",
    shortLabel: "顶级",
    summary: "只放最通用、公开热度最高、最适合作为默认入口的 AI 产品；按 ChatGPT、Claude、Gemini 这三个全球默认入口排序。",
    items: [
      chatgpt,
      claude,
      gemini,
    ],
  },
  {
    id: "openai-suite",
    title: "OpenAI / ChatGPT 生态",
    shortLabel: "OpenAI",
    summary: "先放 OpenAI 的拳头产品 ChatGPT，再放开发者热度最高的 Codex 和平台入口；Deep Research、Canvas、Projects 归入 ChatGPT 能力。",
    moreTarget: "openai-suite",
    moreLabel: "查看更多 OpenAI 生态",
    items: [
      chatgpt,
      codex,
      openaiApiPlatform,
      { name: "Apps SDK", description: "用于构建 ChatGPT Apps 的开发框架，适合把外部服务、MCP 工具和自定义 UI 接入 ChatGPT。", url: "https://developers.openai.com/apps-sdk", country: "us", icon: icon.openai, tags: ["ChatGPT Apps", "SDK", "MCP"], badge: "开发者" },
      { name: "Agent Builder", description: "OpenAI 的可视化 agent 工作流构建入口，适合在平台控制台里搭建、调试和导出 agent 流程。", url: "https://platform.openai.com/agent-builder", country: "us", icon: icon.openai, tags: ["Agent", "构建", "控制台"], badge: "开发者" },
    ],
  },
  {
    id: "anthropic-suite",
    title: "Anthropic / Claude 生态",
    shortLabel: "Claude",
    summary: "先放 Claude 主入口，再放开发者最常用的 Claude Code，最后放面向知识工作的 Cowork 和少量扩展入口。",
    moreTarget: "anthropic-suite",
    moreLabel: "查看更多 Anthropic 生态",
    items: [
      claude,
      claudeCode,
      claudeCowork,
      { name: "Claude Design", description: "Anthropic Labs 的设计实验入口，适合快速产出界面想法、品牌方向和视觉原型。", url: "https://claude.ai/design", country: "us", icon: icon.claude, tags: ["设计", "原型", "Labs"] },
      { name: "Claude for Chrome", description: "浏览器内 Claude 入口，适合网页阅读、页面操作和上下文辅助。", url: "https://chromewebstore.google.com/detail/claude/fcoeoabgfenejglbffodgkkbkcdhcgfn", country: "us", icon: icon.claude, tags: ["浏览器", "网页", "扩展"] },
    ],
  },
  {
    id: "google-suite",
    title: "Google / Gemini 生态",
    shortLabel: "Google",
    summary: "按真实使用热度排序：Gemini 主应用、NotebookLM、AI Studio、Stitch，再补少量开发、创作和搜索入口。",
    moreTarget: "google-suite",
    moreLabel: "查看更多 Google AI 生态",
    items: [
      gemini,
      notebookLm,
      googleAiStudio,
      { name: "Google Stitch", description: "Google Labs 的 AI 产品原型工具，可用自然语言生成高保真移动端和网页 UI，适合从想法快速到可演示界面。", url: "https://stitch.withgoogle.com/", country: "us", icon: icon.gemini, tags: ["AI 原型", "UI", "Google"], badge: "热门" },
      googleAntigravity,
      jules,
      { name: "AI Mode / Search Agents", description: "Google Search 的 AI Mode 入口，适合用搜索式 AI 做复杂问题、追问和多模态检索。", url: "https://search.google/ways-to-search/ai-mode/", country: "us", icon: icon.gemini, tags: ["Search", "AI Mode", "Agent"], badge: "Search" },
      { name: "Google Flow", description: "Google Labs 的 AI 创意视频工作室，和 Gemini、Veo 等能力联动，适合故事和镜头创作。", url: "https://labs.google/fx/tools/flow", country: "us", icon: icon.gemini, tags: ["视频", "创作", "Labs"], badge: "创意" },
    ],
  },
  {
    id: "product-research",
    title: "产品构想 / 调研",
    shortLabel: "构想",
    summary: "从真实社区、趋势和竞品流量里找需求，不只看 AI 生成的想法；适合立项前判断方向值不值得做。",
    items: [
      { name: "Google Trends", description: "观察关键词趋势和地区热度，适合判断需求是不是长期存在。", url: "https://trends.google.com/", country: "us", tags: ["趋势", "关键词", "需求"] },
      { name: "GummySearch", description: "从 Reddit 社区里找痛点、用户表达和细分人群，适合做产品构想和文案提炼。", url: "https://gummysearch.com/", country: "us", tags: ["Reddit", "用户痛点", "调研"] },
      { name: "Similarweb", description: "查看网站流量和来源结构，适合快速判断竞品热度和渠道分布。", url: "https://www.similarweb.com/", country: "us", tags: ["流量", "竞品", "渠道"] },
      { name: "Hacker News", description: "开发者和创业者社区，适合观察新产品、技术趋势和早期反馈。", url: "https://news.ycombinator.com/newest", country: "us", tags: ["开发者", "趋势", "社区"] },
      { name: "Reddit Search", description: "用社区讨论验证真实问题，尤其适合 SaaS、效率工具和自托管产品调研。", url: "https://www.reddit.com/search/", country: "us", tags: ["社区", "痛点", "海外"] },
    ],
  },
  {
    id: "prototype-design",
    title: "产品原型 / 设计",
    shortLabel: "原型设计",
    summary: "从想法到可展示原型：先做界面、动效、截图和演示素材，再决定是否进入完整开发。",
    items: [
      { name: "Figma", description: "主流 UI 设计和协作工具，适合做产品原型、组件库和交互稿。", url: "https://www.figma.com/", country: "us", tags: ["UI", "原型", "协作"] },
      { name: "Google Stitch", description: "Google 的 AI 产品原型工具，适合用自然语言快速生成移动端和网页 UI。", url: "https://stitch.withgoogle.com/", country: "us", icon: icon.gemini, tags: ["AI 原型", "UI", "Google"] },
      { name: "Rotato", description: "App 截图、设备样机和 3D 动效生成工具，适合做官网、商店图和发布素材。", url: "https://rotato.app/", country: "us", tags: ["样机", "动效", "截图"] },
      { name: "Excalidraw", description: "轻量白板和草图工具，适合画产品流程、架构图和粗原型。", url: "https://excalidraw.com/", country: "global", tags: ["白板", "流程图", "开源"] },
      { name: "Uizard", description: "AI 辅助 UI 原型工具，适合从草图、截图或文字生成早期产品界面。", url: "https://uizard.io/", country: "us", tags: ["AI 设计", "原型", "UI"] },
    ],
  },
  {
    id: "dev-hosting",
    title: "开发 / 托管",
    shortLabel: "开发托管",
    summary: "独立产品最常用的开发和上线底座：前端托管、数据库、边缘服务、快速原型和全栈部署。",
    items: [
      { name: "Vercel", description: "前端和全栈 Web 应用托管平台，适合 Next.js、Astro 和产品官网快速上线。", url: "https://vercel.com/", country: "us", tags: ["托管", "前端", "部署"] },
      { name: "Supabase", description: "Postgres、Auth、Storage 和 Edge Functions 一体化平台，适合独立产品后端。", url: "https://supabase.com/", country: "us", tags: ["数据库", "Auth", "后端"] },
      { name: "Cloudflare", description: "域名、DNS、Workers、Pages 和边缘网络平台，适合低成本部署和全球访问。", url: "https://www.cloudflare.com/", country: "us", tags: ["DNS", "Workers", "边缘"] },
      { name: "Replit", description: "在线开发和快速部署平台，适合做原型、脚本和小型 Web 应用。", url: "https://replit.com/", country: "us", tags: ["在线 IDE", "原型", "部署"] },
      { name: "Railway", description: "轻量全栈部署平台，适合服务端、数据库和后台任务快速上线。", url: "https://railway.app/", country: "us", tags: ["全栈", "部署", "数据库"] },
    ],
  },
  {
    id: "api-gateway",
    title: "模型接口 / 聚合",
    shortLabel: "模型接口",
    summary: "给开发者统一调用模型、控制成本和切换供应商的入口；优先放真实可接入的 API 与网关。",
    items: [
      { name: "OpenRouter", description: "多模型 API 聚合平台，适合统一调用不同模型并快速切换供应商。", url: "https://openrouter.ai/", country: "us", tags: ["模型聚合", "API", "多模型"] },
      { name: "AIBerm", description: "面向开发者的折扣 AI API 入口，适合对比模型成本和小产品接入。", url: "https://aiberm.com/", country: "global", tags: ["API", "成本", "模型"] },
      { name: "New API", description: "开源模型网关项目，适合自建统一 API、额度管理和多渠道模型路由。", url: "https://github.com/Calcium-Ion/new-api", country: "global", tags: ["开源", "模型网关", "路由"] },
      { name: "Vercel AI Gateway", description: "Vercel 的模型网关，适合 Web 产品统一接入模型、观测和限流。", url: "https://vercel.com/ai-gateway", country: "us", tags: ["AI Gateway", "Vercel", "Web"] },
      { name: "LiteLLM", description: "开源 LLM 网关和代理层，适合团队统一模型调用、日志和预算控制。", url: "https://www.litellm.ai/", country: "global", tags: ["开源", "代理", "成本"] },
    ],
  },
  {
    id: "launch-growth",
    title: "分发推广 / 社区",
    shortLabel: "分发推广",
    summary: "产品做完之后最关键的是分发：优先放能带来早期用户、开发者反馈和真实讨论的社区与收录平台。",
    items: [
      { name: "Product Hunt", description: "海外产品发布和发现平台，适合 SaaS、开发者工具和独立产品首发。", url: "https://www.producthunt.com/", country: "us", tags: ["发布", "海外", "早期用户"] },
      { name: "V2EX", description: "中文开发者社区，适合分享独立产品、收集技术用户反馈和观察需求。", url: "https://www.v2ex.com/", country: "cn", tags: ["开发者", "中文", "社区"] },
      { name: "小众软件", description: "中文软件发现社区，适合工具类、效率类和小而美产品曝光。", url: "https://www.appinn.com/", country: "cn", tags: ["软件发现", "工具", "中文"] },
      { name: "少数派", description: "高质量效率与数字生活媒体，适合长期内容、教程和产品故事传播。", url: "https://sspai.com/", country: "cn", tags: ["效率", "内容", "媒体"] },
      { name: "Indie Hackers", description: "独立开发者社区，适合分享增长、收入、产品复盘和海外同行经验。", url: "https://www.indiehackers.com/", country: "us", tags: ["独立开发", "增长", "复盘"] },
      { name: "Debut", description: "优质应用发现平台，适合 App、小工具和设计感强的产品收录。", url: "https://debut.so/", country: "us", tags: ["应用收录", "发现", "设计"] },
    ],
  },
  {
    id: "payments-finance",
    title: "收款 / 出海财务",
    shortLabel: "收款财务",
    summary: "独立开发者很容易卡在收款、订阅、结算和公司注册；这里放更常见的出海收款与销售基础设施。",
