      { name: "Payoneer", description: "跨境收款和结算平台，适合接收海外平台款项和多币种资金管理。", url: "https://www.payoneer.com/", country: "us", tags: ["跨境", "结算", "多币种"] },
      { name: "1st Formations", description: "英国公司注册服务，适合需要海外主体、银行账户和合规结构的独立开发者。", url: "https://www.1stformations.co.uk/", country: "uk", tags: ["公司注册", "英国", "出海"] },
