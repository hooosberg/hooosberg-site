---
import {
  ArrowRight,
  BookOpen,
  Code2,
  ExternalLink,
  Layers3,
  Mail,
  Search,
  ShieldCheck,
} from "@lucide/astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductCard from "../components/ProductCard.astro";
import ProductProgressTimeline from "../components/ProductProgressTimeline.astro";
import { productDiaryArticles } from "../data/articles";
import { productsByLatest, socialLinks } from "../data/products";

const featuredProducts = productsByLatest.slice(0, 6);
const featuredArticles = productDiaryArticles.slice(0, 4);
const bilibiliLink = socialLinks.find((link) => link.label === "B站");

const courseTopics = [
  "AI办公自动化",
  "作图软件入门",
  "苹果 App 开发",
  "市场分析",
  "商业调查",
  "开发实战",
  "提示词工作流",
  "产品发布复盘",
];

const tools = [
  { name: "OpenAI Codex", icon: "/icons/ai-tools/openai-codex.svg" },
  { name: "Claude Code", icon: "/icons/ai-tools/claude-code.svg" },
  { name: "Cursor", icon: "/icons/ai-tools/cursor.svg" },
  { name: "GitHub Copilot", icon: "/icons/ai-tools/copilot.svg" },
  { name: "Gemini", icon: "/icons/ai-tools/gemini.svg" },
  { name: "Cline", icon: "/icons/ai-tools/cline.svg" },
  { name: "Windsurf", icon: "/icons/ai-tools/windsurf.svg" },
  { name: "Trae", icon: "/icons/ai-tools/trae.svg" },
  { name: "Roo Code", icon: "/icons/ai-tools/roo-code.svg" },
  { name: "Kiro", icon: "/icons/ai-tools/kiro.svg" },
  { name: "Goose", icon: "/icons/ai-tools/goose.svg" },
  { name: "OpenCode", icon: "/icons/ai-tools/opencode.svg" },
];

const socialCards = socialLinks
  .filter((link) => link.label !== "Email")
  .map((link) => ({ label: link.label, value: "note" in link ? link.note : "平台入口", url: link.url, icon: link.icon }));
---

<BaseLayout
  title="湖森堡AI_hooosberg | 哲学 艺术 AI"
  description="分享 AI 时代真实产品开发、思考过程、产品日记和独立开发历险。"
>
  <section class="landing-hero">
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="hero-content">
      <p class="hero-kicker">真实开发过程 / 失败经验 / AI 对话源文件</p>
      <h1>哲学 艺术 AI</h1>
      <p class="hero-subtitle">
        AI 时代不需要一个固定教程，也不需要把所有答案包装成标准流程。
        这里记录真实产品：成功、失败、判断失误和改方向的过程。
        我会尽量留下需求、提示词、代码、发布和复盘，让你看到人如何和 AI 一起思考。
      </p>
      <div class="hero-actions">
        <a class="button button--primary button--xl" href="/blog">
          <BookOpen size={18} aria-hidden="true" />
          产品日记
        </a>
        <a class="button button--secondary button--xl" href="#about">
          <Mail size={18} aria-hidden="true" />
          联系我们
        </a>
      </div>
      <div class="hero-proof" aria-label="Site focus">
        <span>成功产品</span>
        <span>失败复盘</span>
        <span>人的判断</span>
        <span>真实 AI 对话</span>
      </div>
    </div>
  </section>

  <section class="tools-band" aria-label="AI coding tools">
    <p class="tools-label">我们用到的 AI 编程工具</p>
    <div class="tools-track-wrapper">
      <div class="tools-track">
        {[...tools, ...tools].map((tool) => (
          <a class="tool-item" href="/blog" aria-label={tool.name}>
            <img src={tool.icon} alt="" />
            <span>{tool.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="landing-section home-directory-section" id="ai-navigation">
    <div class="section-heading section-heading--center">
      <p>AI 导航</p>
      <h2>先选对工具。</h2>
      <span>主流工具、国内平替、开发资源和学习资料都放进一页，按场景快速跳转。</span>
    </div>

    <div class="home-directory-panel">
      <div class="home-directory-intro">
        <div>
          <p class="home-directory-kicker">快速入口</p>
          <h3>排行榜、平替、资源入口。</h3>
          <p>
            导航页会持续整理我实际使用或完整调研过的工具：AI 编程、模型接口、产品原型、
            设计创作、开发托管、分发推广和免费学习资源，方便你按场景直接跳转。
          </p>
        </div>
        <div class="home-directory-actions">
          <a class="button button--primary" href="/ai-navigation">
            进入 AI 导航
            <ArrowRight size={17} aria-hidden="true" />
          </a>
          <a class="button button--secondary" href="/ai-navigation#top">看顶级产品榜</a>
        </div>
      </div>

      <div class="home-directory-card-grid" aria-label="AI 导航快速入口">
        <a class="home-directory-card" href="/ai-navigation">
          <span class="home-directory-icon"><Search size={20} aria-hidden="true" /></span>
          <strong>AI 工具排行榜</strong>
          <p>从 ChatGPT、Claude、Gemini 到国内主流工具，先看最值得反复使用的入口。</p>
        </a>
        <a class="home-directory-card" href="/ai-navigation#dev-hosting">
          <span class="home-directory-icon"><Code2 size={20} aria-hidden="true" /></span>
          <strong>开发者工具链</strong>
          <p>模型接口、开发托管、原型设计和分发推广，适合做产品前快速选型。</p>
        </a>
        <a class="home-directory-card" href="/ai-navigation">
          <span class="home-directory-icon"><Layers3 size={20} aria-hidden="true" /></span>
          <strong>国内平替对照</strong>
          <p>把国际主流产品和国内可用工具放在一起，方便判断该用哪个替代。</p>
        </a>
        <a class="home-directory-card" href="/ai-navigation#free-learning">
          <span class="home-directory-icon"><ShieldCheck size={20} aria-hidden="true" /></span>
          <strong>长期学习资源</strong>
          <p>只放值得长期看的免费课程和一线资料，给后续课程与项目打基础。</p>
        </a>
      </div>
    </div>
  </section>

  <section class="landing-section">
    <div class="section-heading">
      <p>产品与复盘</p>
      <h2>真实产品，真实输赢。</h2>
      <span>成功产品会展示，失败产品也会展示，重点写清为什么失败。单看教程不够，实战才会真正提高。</span>
      <a href="/apps">全部产品 <ArrowRight size={15} aria-hidden="true" /></a>
    </div>
    <div class="product-grid product-grid--catalog">
      {featuredProducts.map((product) => <ProductCard product={product} />)}
    </div>
    <ProductProgressTimeline compact />
  </section>

  <section class="landing-section landing-section--split" id="articles">
    <div class="section-heading">
      <p>开发日记</p>
      <h2>把产品从想法到发布拆开写。</h2>
      <a href="/blog">日记列表 <ArrowRight size={15} aria-hidden="true" /></a>
    </div>
    <div class="article-list article-list--compact">
      {featuredArticles.map((article) => (
        <a class="article-row" href={`/blog/${article.slug}`}>
          <span class="article-row__category">{article.category}</span>
          <span class="article-row__title">{article.title}</span>
          <span class="article-row__excerpt">{article.excerpt}</span>
          <span class="article-row__date">{article.date}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="author-section" id="about">
    <div class="author-card">
      <div class="author-mark">
        <img src="/brand/hooosberg-ai-icon.png" alt="" />
      </div>
      <div>
        <p class="hero-kicker">关于湖森堡AI_hooosberg</p>
        <h2>一个在艺术、建筑和技术之间做产品的独立开发者。</h2>
        <div class="author-card__copy">
          <p>
            我毕业于美术学院，本身学的是建筑设计，也长期喜欢研究技术和编程。过去做过 3D 打印，拍过户外纪录片，
            也一直在把空间、影像、工具和产品开发放在同一个系统里思考。
          </p>
          <p>
            现在我正在 all in AI。2026 上半年已经开发并发布了十多个产品，目标是今年完成 20 个，慢慢形成稳定的海外收入。
            这是我的梦想，这个网站会记录路上的产品、课程、核心文件、AI 对话和复盘，也希望把这场历险一路分享给你。
          </p>
        </div>
      </div>
    </div>

    <div class="social-card-grid">
      {socialCards.map((link) => (
        <a class="social-card" href={link.url} target={link.url.startsWith("http") ? "_blank" : undefined} rel="noreferrer">
          <img class="social-card__icon" src={link.icon} alt="" loading="lazy" decoding="async" />
          <span>{link.label}</span>
          <strong>{link.value}</strong>
          {link.url.startsWith("http") && <ExternalLink class="social-card__external" size={14} aria-hidden="true" />}
        </a>
      ))}
    </div>
  </section>

  <section class="faq-section" id="faq">
    <div class="section-heading section-heading--center">
      <p>常见问题</p>
      <h2>如果你是从视频或产品介绍过来的，可以先看这里。</h2>
    </div>
    <div class="faq-list">
      <details open>
        <summary>我在短视频里看到某个 AI 产品，在哪里下载或了解？</summary>
        <p>可以先看首页的产品区，里面会放我已经发布或正在迭代的工具。每个产品会尽量补上介绍、下载入口、隐私政策和支持方式；如果某个视频里的产品还没放出来，通常说明它还在测试或整理上架材料。</p>
      </details>
      <details>
        <summary>这里主要是卖课，还是分享工具和真实案例？</summary>
        <p>两件事都会做，但重点不是空讲概念。我会围绕真实产品、真实办公流程和真实发布过程，拆解 AI 编程、Codex 自动化、文件处理、浏览器操作和批量生产这些场景，让你看到一个工具从想法到上线的路径。</p>
      </details>
      <details>
        <summary>零基础能跟着学吗？需要先会编程吗？</summary>
        <p>可以从零基础开始，但最好愿意动手。公开视频会先解决工具入门和案例理解；更系统的课程会把需求拆解、提示词、代码修改、调试、发布和复盘连起来，不要求你一开始就像程序员一样写代码。</p>
      </details>
      <details>
        <summary>课程、资料和更新会放在哪里？</summary>
        <p>公开视频会优先放在 B 站、抖音、小红书等平台；系统课程、资料包或项目文档会根据当时最合适的方式交付。这个网站会作为统一入口，把视频、产品、课程资料和后续支持连接起来。</p>
      </details>
      <details>
        <summary>我想把 AI 用到工作、内容生产或自己的产品里，应该先看什么？</summary>
        <p>可以先从你最接近的入口开始：想做工具就看产品案例，想提升效率就看办公自动化，想学 AI 编程就看课程和教程。后面我会把常用流程、提示词、案例复盘和可下载工具逐步整理到这里。</p>
      </details>
    </div>
  </section>

  <section class="landing-section home-course-section" id="courses">
    <div class="section-heading section-heading--center">
      <p>课程</p>
      <h2>课程不是终点，是入口。</h2>
      <span>可以购买，可以交付，也会持续更新。真实项目里的需求、提示词、代码、素材、发布和复盘都会留下路径。</span>
    </div>

    <a
      class="premium-course-card premium-course-card--portrait home-premium-course-card"
      href={bilibiliLink?.url ?? "/courses"}
      target={bilibiliLink?.url ? "_blank" : undefined}
      rel={bilibiliLink?.url ? "noreferrer" : undefined}
    >
      <span class="premium-course-card__ribbon">Coming Soon</span>
      <span class="premium-course-card__eyebrow">Hooosberg AI Course</span>
      <h2>入门Ai编程实践课程</h2>
      <div class="premium-course-card__price" aria-label="课程定价">
        <strong>1499元</strong>
        <span>限时课程定价</span>
      </div>
      <p>
        从零到一完成 AI 编程、自动化办公、产品调研、App 开发和上线复盘。
        不做碎片技巧堆砌，只围绕能真正交付的项目练习。
      </p>

      <div class="premium-course-topics" aria-label="课程内容方向">
        {courseTopics.map((topic) => <span>{topic}</span>)}
      </div>

      <span class="premium-course-card__action">
        <BookOpen size={18} aria-hidden="true" />
        立即购买
        <ArrowRight size={17} aria-hidden="true" />
      </span>
    </a>
  </section>
</BaseLayout>
