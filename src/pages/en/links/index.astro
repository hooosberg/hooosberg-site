---
import { ExternalLink } from "@lucide/astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getLocalizedSocialLinks } from "../../../utils/i18n";
import { buildSectionWebPageJsonLd } from "../../../utils/structuredData";

const linkCards = getLocalizedSocialLinks("en");

const videoLabels = ["YouTube", "B站", "抖音", "快手", "TikTok"];
const socialLabels = ["GitHub", "X", "小红书"];
const directLabels = ["Email", "Telegram"];

const getCards = (labels: string[]) =>
  labels.map((label) => linkCards.find((link) => link.originalLabel === label)).filter(Boolean);

const contactSections = [
  {
    title: "Video channels",
    kicker: "Tutorials, product demos, AI workflows, and real build process.",
    cards: getCards(videoLabels),
    className: "platform-card-grid--video",
  },
  {
    title: "Social media",
    kicker: "Daily thoughts, product updates, source code, and public notes.",
    cards: getCards(socialLabels),
    className: "platform-card-grid--social",
  },
  {
    title: "Email and Telegram",
    kicker: "Courses, products, collaboration, and technical conversation.",
    cards: getCards(directLabels),
    className: "platform-card-grid--direct",
  },
];
const pageDescription = "Hooosberg video channels, social profiles, email, and Telegram contact links.";
const jsonLd = buildSectionWebPageJsonLd({
  locale: "en",
  path: "/en/links",
  name: "Hooosberg Official Links",
  description: pageDescription,
  topics: ["Hooosberg official links", "Hooosberg contact", "social profiles", "official support"],
});
---

<BaseLayout
  locale="en"
  title="Contact | Hooosberg"
  description={pageDescription}
  canonicalPath="/en/links"
  jsonLd={jsonLd}
>
  <section class="page-hero page-hero--narrow">
    <h1>Contact</h1>
    <p>Find Hooosberg through video channels, social platforms, email, and Telegram.</p>
  </section>

  <section class="link-hub">
    {contactSections.map((section) => (
      <div class="contact-platform-section">
        <div class="contact-platform-section__heading">
          <span>{section.title}</span>
          <p>{section.kicker}</p>
        </div>
        <div class={`platform-card-grid ${section.className}`}>
          {section.cards.map((link) => (
            <a class="platform-card" href={link.url} target={link.url.startsWith("http") ? "_blank" : undefined} rel="noreferrer">
              <img class="platform-card__icon" src={link.icon} alt="" loading="lazy" decoding="async" />
              <span>{link.note}</span>
              <strong>{link.label}</strong>
              <small>{link.handle}</small>
              {link.url.startsWith("http") && <ExternalLink class="platform-card__external" size={16} aria-hidden="true" />}
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>
</BaseLayout>
