---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ProductCard from "../../../components/ProductCard.astro";
import { productsByLatest } from "../../../data/products";
import { buildItemListJsonLd, buildSectionCollectionJsonLd } from "../../../utils/structuredData";

const pageDescription = "Apps, AI tools, postmortems, and developer products built by Hooosberg.";
const productItems = productsByLatest.map((product) => ({
  name: product.displayName,
  url: `/en/apps/${product.slug}`,
  description: product.summary,
}));
const jsonLd = [
  buildSectionCollectionJsonLd({
    locale: "en",
    path: "/en/apps",
    name: "Hooosberg Products",
    description: pageDescription,
    topics: ["indie AI apps", "local-first AI apps", "AI developer tools", "Hooosberg products"],
  }),
  buildItemListJsonLd("https://hooosberg.com/en/apps#product-list", productItems),
];
---

<BaseLayout
  locale="en"
  title="Products | Hooosberg"
  description={pageDescription}
  canonicalPath="/en/apps"
  jsonLd={jsonLd}
>
  <section class="page-hero page-hero--narrow">
    <h1>Products</h1>
    <p>
      A product matrix of apps, AI tools, browser utilities, quiet games, and honest postmortems.
      Each product page connects downloads, source code, privacy, support, and build diaries under one domain.
    </p>
  </section>

  <section class="catalog-section">
    <div class="product-grid product-grid--catalog">
      {productsByLatest.map((product) => <ProductCard product={product} locale="en" />)}
    </div>
  </section>
</BaseLayout>
