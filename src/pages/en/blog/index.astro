---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { articlesByDate } from "../../../data/articles";
import { diarySectionsLocalized, getLocalizedArticle } from "../../../utils/i18n";
import { buildItemListJsonLd, buildSectionCollectionJsonLd } from "../../../utils/structuredData";

const articlesPerPage = 15;
const localizedArticles = articlesByDate.map((article) => getLocalizedArticle(article, "en"));
const diaryGroups = diarySectionsLocalized.en.map((section) => ({
  ...section,
  articles: localizedArticles.filter((article) => article.diaryKind === section.kind),
}));

const articleHref = (slug: string, kind: string) => `/en/blog/${slug}?kind=${kind}`;
const pageDescription = "Product diaries, reading notes, resource notes, and essays about AI, indie apps, product launches, and real build decisions.";
const jsonLd = [
  buildSectionCollectionJsonLd({
    locale: "en",
    path: "/en/blog",
    name: "Hooosberg Build Diaries",
    description: pageDescription,
    topics: ["AI product build diaries", "indie app development", "AI coding case studies", "App Store review lessons"],
  }),
  buildItemListJsonLd(
    "https://hooosberg.com/en/blog#article-list",
    localizedArticles.map((article) => ({
      name: article.title,
      url: `/en/blog/${article.slug}`,
      description: article.excerpt,
    })),
  ),
];
---

<BaseLayout
  locale="en"
  title="Journal | Hooosberg"
  description={pageDescription}
  canonicalPath="/en/blog"
  jsonLd={jsonLd}
>
  <section class="page-hero page-hero--narrow">
    <p class="commerce-kicker">Journal</p>
    <h1>Journal</h1>
    <p>
      Product diaries, reading notes, resource notes, and essays. The product diary is the main asset:
      each article turns a real build step into a reusable case study.
    </p>
  </section>

  <section class="article-index">
    <div class="diary-switch" role="tablist" aria-label="Journal sections">
      {diaryGroups.map((section, index) => (
        <button
          class="diary-tab"
          type="button"
          role="tab"
          aria-selected={index === 0 ? "true" : "false"}
          aria-controls={`diary-panel-${section.kind}`}
          data-diary-tab={section.kind}
          data-active={index === 0 ? "true" : "false"}
        >
          <span>{section.label}</span>
          <small>{section.articles.length} posts</small>
        </button>
      ))}
    </div>

    <div class="diary-summary-grid" aria-live="polite">
      {diaryGroups.map((section, index) => (
        <p
          id={`diary-panel-${section.kind}`}
          role="tabpanel"
          data-diary-summary={section.kind}
          hidden={index !== 0}
        >
          {section.summary}
        </p>
      ))}
    </div>

    <div class="article-list">
      {diaryGroups.map((section, index) => (
        section.articles.map((article, articleIndex) => (
          <a
            class="article-row"
            href={articleHref(article.slug, section.kind)}
            data-diary-row
            data-diary-kind={section.kind}
            data-diary-page={Math.floor(articleIndex / articlesPerPage) + 1}
            hidden={index !== 0 || articleIndex >= articlesPerPage}
          >
            <span class="article-row__category">{section.kind === "product" ? article.productLabel ?? article.category : article.category}</span>
            <span class="article-row__title">{article.title}</span>
            <span class="article-row__excerpt">{article.excerpt}</span>
            <span class="article-row__date">{article.date}</span>
          </a>
        ))
      ))}
    </div>

    {diaryGroups.map((section, index) => {
      const pageCount = Math.ceil(section.articles.length / articlesPerPage);
      return (
        <nav
          class="diary-pagination"
          aria-label={`${section.label} pagination`}
          data-diary-pagination={section.kind}
          hidden={index !== 0 || pageCount <= 1}
        >
          {Array.from({ length: pageCount }, (_, pageIndex) => {
            const page = pageIndex + 1;
            return (
              <button
                class="diary-page-button"
                type="button"
                data-diary-page-button
                data-diary-kind={section.kind}
                data-diary-page={page}
                aria-current={page === 1 ? "page" : undefined}
              >
                {page}
              </button>
            );
          })}
        </nav>
      );
    })}
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    const tabs = Array.from(document.querySelectorAll("[data-diary-tab]"));
    const rows = Array.from(document.querySelectorAll("[data-diary-row]"));
    const summaries = Array.from(document.querySelectorAll("[data-diary-summary]"));
    const paginations = Array.from(document.querySelectorAll("[data-diary-pagination]"));
    const pageButtons = Array.from(document.querySelectorAll("[data-diary-page-button]"));
    const validKinds = new Set(tabs.map((tab) => tab.dataset.diaryTab));

    const syncUrl = (kind, page) => {
      const url = new URL(window.location.href);
      url.searchParams.set("kind", kind);
      if (page > 1) {
        url.searchParams.set("page", String(page));
      } else {
        url.searchParams.delete("page");
      }
      window.history.replaceState({ diaryKind: kind }, "", `${url.pathname}${url.search}${url.hash}`);
    };

    const getPageCount = (kind) => {
      const pages = pageButtons
        .filter((button) => button.dataset.diaryKind === kind)
        .map((button) => Number(button.dataset.diaryPage || "1"));
      return Math.max(1, ...pages);
    };

    const activate = (kind, options = {}) => {
      if (!kind || !validKinds.has(kind)) return;
      const pageCount = getPageCount(kind);
      const requestedPage = Number(options.page || "1");
      const activePage = Math.min(Math.max(1, requestedPage || 1), pageCount);

      tabs.forEach((tab) => {
        const active = tab.dataset.diaryTab === kind;
        tab.dataset.active = active ? "true" : "false";
        tab.setAttribute("aria-selected", active ? "true" : "false");
      });
      rows.forEach((row) => {
        row.hidden = row.dataset.diaryKind !== kind || Number(row.dataset.diaryPage || "1") !== activePage;
      });
      summaries.forEach((summary) => {
        summary.hidden = summary.dataset.diarySummary !== kind;
      });
      paginations.forEach((pagination) => {
        pagination.hidden = pagination.dataset.diaryPagination !== kind || pageCount <= 1;
      });
      pageButtons.forEach((button) => {
        const active = button.dataset.diaryKind === kind && Number(button.dataset.diaryPage || "1") === activePage;
        button.setAttribute("aria-current", active ? "page" : "false");
      });

      if (options.syncUrl) syncUrl(kind, activePage);
    };

    const searchParams = new URLSearchParams(window.location.search);
    const initialKind = searchParams.get("kind");
    const initialPage = Number(searchParams.get("page") || "1");
    activate(initialKind || tabs[0]?.dataset.diaryTab, { page: initialPage });

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => activate(tab.dataset.diaryTab, { page: 1, syncUrl: true }));
    });
    pageButtons.forEach((button) => {
      button.addEventListener("click", () => {
        activate(button.dataset.diaryKind, {
          page: Number(button.dataset.diaryPage || "1"),
          syncUrl: true,
        });
      });
    });
  })();
</script>
