---
import { ExternalLink, Mail, Search } from "@lucide/astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getLocalizedSocialLinks } from "../../../utils/i18n";
import { buildItemListJsonLd, buildSectionCollectionJsonLd } from "../../../utils/structuredData";

type CountryCode = "us" | "cn" | "uk" | "au" | "ca" | "fr" | "global";

type ToolItem = {
  name: string;
  description: string;
  url: string;
  country: CountryCode;
  icon?: string;
  tags: string[];
  badge?: string;
};

type ToolSection = {
  title: string;
  summary: string;
  items: ToolItem[];
};

type ToolGroup = {
  id: string;
  title: string;
  shortLabel: string;
  summary: string;
  items?: ToolItem[];
  sections?: ToolSection[];
};

type AlternativePair = {
  id: string;
  category: string;
  source: ToolItem;
  alternatives: ToolItem[];
  reason: string;
  bestFor: string[];
};

const countryMeta: Record<CountryCode, { flag: string; name: string; access: string; tone: "limited" | "easy" | "neutral" }> = {
  us: { flag: "US", name: "United States", access: "Global availability varies", tone: "limited" },
  cn: { flag: "CN", name: "China", access: "Strong Chinese-language access", tone: "easy" },
  uk: { flag: "UK", name: "United Kingdom", access: "Availability varies", tone: "neutral" },
  au: { flag: "AU", name: "Australia", access: "Availability varies", tone: "neutral" },
  ca: { flag: "CA", name: "Canada", access: "Availability varies", tone: "neutral" },
  fr: { flag: "FR", name: "France", access: "Availability varies", tone: "neutral" },
  global: { flag: "GLOBAL", name: "Global / open source", access: "Depends on deployment", tone: "neutral" },
};

const icon = {
  openai: "/icons/ai-tools/openai-codex.svg",
  claude: "/icons/ai-tools/claude-code.svg",
  gemini: "/icons/ai-tools/gemini.svg",
  antigravity: "/icons/ai-tools/antigravity.svg",
  copilot: "/icons/ai-tools/copilot.svg",
  cursor: "/icons/ai-tools/cursor.svg",
  windsurf: "/icons/ai-tools/windsurf.svg",
  trae: "/icons/ai-tools/trae.svg",
  cline: "/icons/ai-tools/cline.svg",
  roo: "/icons/ai-tools/roo-code.svg",
  opencode: "/icons/ai-tools/opencode.svg",
  kiro: "/icons/ai-tools/kiro.svg",
};

const tool = (item: ToolItem): ToolItem => item;

const chatgpt = tool({
  name: "ChatGPT",
  description: "OpenAI's general AI assistant and the main entry for Projects, Canvas, voice, images, deep research, and agent workflows.",
  url: "https://chatgpt.com/",
  country: "us",
  icon: icon.openai,
  tags: ["assistant", "multimodal", "default"],
  badge: "Essential",
});

const claude = tool({
  name: "Claude",
  description: "Anthropic's assistant for long context, writing, careful reasoning, code understanding, and complex multi-step tasks.",
  url: "https://claude.ai/",
  country: "us",
  icon: icon.claude,
  tags: ["writing", "long context", "reasoning"],
  badge: "Essential",
});

const gemini = tool({
  name: "Gemini",
  description: "Google's AI assistant connected to multimodal work, search, Workspace, NotebookLM, and the broader Google AI ecosystem.",
  url: "https://gemini.google.com/app",
  country: "us",
  icon: icon.gemini,
  tags: ["Google", "multimodal", "search"],
  badge: "Essential",
});

const codex = tool({
  name: "OpenAI Codex",
  description: "OpenAI's coding agent for repository-level code tasks, debugging, refactoring, builds, and code review.",
  url: "https://chatgpt.com/codex/",
  country: "us",
  icon: icon.openai,
  tags: ["coding", "agent", "OpenAI"],
  badge: "Builder",
});

const openaiApiPlatform = tool({
  name: "OpenAI API Platform",
  description: "OpenAI's API, model, documentation, and app-building entry point for bringing ChatGPT, Codex, and agent capabilities into products.",
  url: "https://platform.openai.com/",
  country: "us",
  icon: icon.openai,
  tags: ["API", "models", "developer"],
  badge: "Builder",
});

const claudeCode = tool({
  name: "Claude Code",
  description: "Anthropic's terminal coding agent for project understanding, edits, tests, Git workflows, and long-running repository tasks.",
  url: "https://claude.ai/code",
  country: "us",
  icon: icon.claude,
  tags: ["terminal", "coding", "agent"],
  badge: "Builder",
});

const claudeCowork = tool({
  name: "Claude Cowork",
  description: "Anthropic's agentic workspace direction for knowledge work, files, apps, and multi-step deliverables.",
  url: "https://www.anthropic.com/product/claude-cowork",
  country: "us",
  icon: icon.claude,
  tags: ["team", "workflow", "knowledge work"],
});

const notebookLm = tool({
  name: "NotebookLM",
  description: "Google's source-grounded research and note tool for reading files, asking questions over materials, summaries, and audio overviews.",
  url: "https://notebooklm.google/",
  country: "us",
  icon: icon.gemini,
  tags: ["research", "notes", "sources"],
});

const googleAiStudio = tool({
  name: "Google AI Studio",
  description: "Gemini API, prompt testing, model experiments, and developer prototyping for Gemini-powered products.",
  url: "https://aistudio.google.com/",
  country: "us",
  icon: icon.gemini,
  tags: ["Gemini", "API", "developer"],
  badge: "Builder",
});

const googleAntigravity = tool({
  name: "Google Antigravity",
  description: "Google's agent-first development platform for Gemini-driven planning, execution, and verification of software tasks.",
  url: "https://antigravity.google/",
  country: "us",
  icon: icon.antigravity,
  tags: ["IDE", "agent", "Google"],
});

const jules = tool({
  name: "Jules",
  description: "Google's asynchronous coding agent for handing code tasks to a cloud agent and reviewing the results later.",
  url: "https://jules.google.com/",
  country: "us",
  icon: icon.gemini,
  tags: ["coding", "async", "agent"],
});

const kimi = tool({
  name: "Kimi",
  description: "Moonshot AI's assistant for long documents, search, slides, spreadsheets, and agent-style workflows in Chinese contexts.",
  url: "https://www.kimi.com/",
  country: "cn",
  tags: ["long documents", "search", "agent"],
  badge: "China",
});

const doubao = tool({
  name: "Doubao",
  description: "ByteDance's mainstream AI assistant for chat, images, audio, video, mobile usage, and broad consumer workflows.",
  url: "https://www.doubao.com/",
  country: "cn",
  tags: ["multimodal", "mobile", "ByteDance"],
  badge: "China",
});

const qwen = tool({
  name: "Qwen",
  description: "Alibaba's Qwen assistant and model ecosystem for Chinese, office work, coding, and developer platform workflows.",
  url: "https://chat.qwen.ai/",
  country: "cn",
  tags: ["Qwen", "models", "Chinese"],
  badge: "China",
});

const deepseek = tool({
  name: "DeepSeek",
  description: "Highly watched Chinese model and assistant entry for reasoning, coding, Chinese Q&A, and cost-sensitive APIs.",
  url: "https://chat.deepseek.com/",
  country: "cn",
  tags: ["reasoning", "code", "models"],
  badge: "China",
});

const trae = tool({
  name: "TRAE",
  description: "ByteDance's AI coding tool for IDE, web, and mobile development workflows.",
  url: "https://www.trae.ai/",
  country: "cn",
  icon: icon.trae,
  tags: ["IDE", "agent", "ByteDance"],
  badge: "China",
});

const codebuddy = tool({
  name: "WorkBuddy (CodeBuddy)",
  description: "Tencent Cloud CodeBuddy's AI agent workspace for planning and delivering multimodal complex tasks with parallel agents, now a top regional Codex alternative to watch.",
  url: "https://www.codebuddy.cn/work/",
  country: "cn",
  tags: ["coding", "agent", "Tencent"],
  badge: "Recommended",
});

const groups: ToolGroup[] = [
  {
    id: "top",
    title: "Top AI Products",
    shortLabel: "Top",
    summary: "The default global entry points: broad, mature, and useful across many workflows.",
    items: [chatgpt, claude, gemini],
  },
  {
    id: "openai-suite",
    title: "OpenAI / ChatGPT Ecosystem",
    shortLabel: "OpenAI",
    summary: "ChatGPT first, then the developer products most relevant to builders: Codex, the API platform, Apps SDK, and Agent Builder.",
    items: [
      chatgpt,
      codex,
      openaiApiPlatform,
      { name: "Apps SDK", description: "Framework for building ChatGPT Apps with external services, MCP tools, and custom UI inside ChatGPT.", url: "https://developers.openai.com/apps-sdk", country: "us", icon: icon.openai, tags: ["ChatGPT Apps", "SDK", "MCP"], badge: "Builder" },
      { name: "Agent Builder", description: "Visual agent workflow builder for designing, debugging, and exporting agent flows from the OpenAI platform.", url: "https://platform.openai.com/agent-builder", country: "us", icon: icon.openai, tags: ["agent", "workflow", "console"], badge: "Builder" },
    ],
  },
  {
    id: "anthropic-suite",
    title: "Anthropic / Claude Ecosystem",
    shortLabel: "Claude",
    summary: "Claude as the main app, Claude Code for software work, and Anthropic's newer knowledge-work and browser directions.",
    items: [
      claude,
      claudeCode,
      claudeCowork,
      { name: "Claude Design", description: "Anthropic Labs design experiment for quickly exploring interface ideas, brand direction, and visual prototypes.", url: "https://claude.ai/design", country: "us", icon: icon.claude, tags: ["design", "prototype", "Labs"] },
      { name: "Claude for Chrome", description: "Browser-side Claude entry for reading pages, operating in web context, and keeping assistance closer to the page.", url: "https://chromewebstore.google.com/detail/claude/fcoeoabgfenejglbffodgkkbkcdhcgfn", country: "us", icon: icon.claude, tags: ["browser", "extension", "web"] },
    ],
  },
  {
    id: "google-suite",
    title: "Google / Gemini Ecosystem",
    shortLabel: "Google",
    summary: "Gemini, NotebookLM, AI Studio, Stitch, Antigravity, Jules, Search AI Mode, and Flow as the practical Google AI surface map.",
    items: [
      gemini,
      notebookLm,
      googleAiStudio,
      { name: "Google Stitch", description: "Google Labs AI prototyping tool for generating high-fidelity mobile and web UI from natural language.", url: "https://stitch.withgoogle.com/", country: "us", icon: icon.gemini, tags: ["AI prototype", "UI", "Google"], badge: "Hot" },
      googleAntigravity,
      jules,
      { name: "AI Mode / Search Agents", description: "Google Search's AI Mode entry for complex search, follow-up questions, and multimodal research.", url: "https://search.google/ways-to-search/ai-mode/", country: "us", icon: icon.gemini, tags: ["search", "AI Mode", "agent"], badge: "Search" },
      { name: "Google Flow", description: "Google Labs creative video workspace connected to Gemini and Veo for story, scene, and camera exploration.", url: "https://labs.google/fx/tools/flow", country: "us", icon: icon.gemini, tags: ["video", "creative", "Labs"], badge: "Creative" },
    ],
  },
  {
    id: "product-research",
    title: "Product Ideas / Research",
    shortLabel: "Research",
    summary: "Use search demand, communities, competitor traffic, and real user language before committing to a product direction.",
    items: [
      { name: "Google Trends", description: "Keyword trends and regional interest for checking whether demand exists beyond a single moment.", url: "https://trends.google.com/", country: "us", tags: ["trends", "keywords", "demand"] },
      { name: "GummySearch", description: "Find Reddit pain points, user language, and niche audiences for product ideas and copy research.", url: "https://gummysearch.com/", country: "us", tags: ["Reddit", "pain points", "research"] },
      { name: "Similarweb", description: "Website traffic and channel structure for quick competitor and market-interest checks.", url: "https://www.similarweb.com/", country: "us", tags: ["traffic", "competitors", "channels"] },
      { name: "Hacker News", description: "Developer and startup community for product launches, technical feedback, and trend observation.", url: "https://news.ycombinator.com/newest", country: "us", tags: ["developers", "trends", "community"] },
      { name: "Reddit Search", description: "Community discussions for validating real problems, especially SaaS, productivity, and self-hosted products.", url: "https://www.reddit.com/search/", country: "us", tags: ["community", "pain points", "global"] },
    ],
  },
  {
    id: "prototype-design",
    title: "Product Prototype / Design",
    shortLabel: "Prototype",
    summary: "From idea to presentable prototype: interfaces, motion, screenshots, demos, and launch visuals before full development.",
    items: [
      { name: "Figma", description: "Mainstream UI design and collaboration tool for prototypes, component systems, and interaction specs.", url: "https://www.figma.com/", country: "us", tags: ["UI", "prototype", "collaboration"] },
      { name: "Google Stitch", description: "AI product prototyping from natural language into mobile and web UI concepts.", url: "https://stitch.withgoogle.com/", country: "us", icon: icon.gemini, tags: ["AI prototype", "UI", "Google"] },
      { name: "Rotato", description: "App screenshots, device mockups, and 3D motion assets for websites, stores, and launch materials.", url: "https://rotato.app/", country: "us", tags: ["mockups", "motion", "screenshots"] },
      { name: "Excalidraw", description: "Lightweight whiteboard for product flows, system diagrams, architecture sketches, and rough prototypes.", url: "https://excalidraw.com/", country: "global", tags: ["whiteboard", "diagrams", "open source"] },
      { name: "Uizard", description: "AI-assisted UI prototype tool for turning sketches, screenshots, or text into early product interfaces.", url: "https://uizard.io/", country: "us", tags: ["AI design", "prototype", "UI"] },
    ],
  },
  {
    id: "dev-hosting",
    title: "Development / Hosting",
    shortLabel: "Hosting",
    summary: "The practical stack for small products: frontend hosting, databases, edge services, prototypes, and full-stack deployment.",
    items: [
      { name: "Vercel", description: "Frontend and full-stack hosting for Next.js, Astro, product sites, and modern web apps.", url: "https://vercel.com/", country: "us", tags: ["hosting", "frontend", "deploy"] },
      { name: "Supabase", description: "Postgres, Auth, Storage, and Edge Functions for indie product backends.", url: "https://supabase.com/", country: "us", tags: ["database", "auth", "backend"] },
      { name: "Cloudflare", description: "DNS, Pages, Workers, edge runtime, CDN, and low-cost global deployment.", url: "https://www.cloudflare.com/", country: "us", tags: ["DNS", "Workers", "edge"] },
      { name: "Replit", description: "Online development and deployment for prototypes, scripts, and small web applications.", url: "https://replit.com/", country: "us", tags: ["online IDE", "prototype", "deploy"] },
      { name: "Railway", description: "Lightweight full-stack deployment for servers, databases, and background jobs.", url: "https://railway.app/", country: "us", tags: ["full-stack", "deploy", "database"] },
    ],
  },
  {
    id: "api-gateway",
    title: "Model APIs / Gateways",
    shortLabel: "APIs",
    summary: "Model access, cost control, provider switching, and unified API layers for product builders.",
    items: [
      { name: "OpenRouter", description: "Multi-model API gateway for switching model providers and managing model cost tradeoffs.", url: "https://openrouter.ai/", country: "us", tags: ["model gateway", "API", "multi-model"] },
      { name: "AIBerm", description: "Discount AI API entry for comparing model costs and connecting small products quickly.", url: "https://aiberm.com/", country: "global", tags: ["API", "cost", "models"] },
      { name: "New API", description: "Open-source model gateway for self-hosted unified API, quota management, and channel routing.", url: "https://github.com/Calcium-Ion/new-api", country: "global", tags: ["open source", "gateway", "routing"] },
      { name: "Vercel AI Gateway", description: "Vercel's model gateway for web products that need unified model access, observation, and limits.", url: "https://vercel.com/ai-gateway", country: "us", tags: ["AI Gateway", "Vercel", "web"] },
      { name: "LiteLLM", description: "Open-source LLM gateway and proxy for shared logging, budgets, and provider routing.", url: "https://www.litellm.ai/", country: "global", tags: ["open source", "proxy", "cost"] },
    ],
  },
  {
    id: "launch-growth",
    title: "Launch / Distribution",
    shortLabel: "Launch",
    summary: "Distribution is the hard part after shipping: early users, developer feedback, directories, and credible launch communities.",
    items: [
      { name: "Product Hunt", description: "Global product launch and discovery platform for SaaS, developer tools, and indie products.", url: "https://www.producthunt.com/", country: "us", tags: ["launch", "global", "early users"] },
      { name: "V2EX", description: "Chinese developer community for sharing indie products, collecting technical feedback, and observing user needs.", url: "https://www.v2ex.com/", country: "cn", tags: ["developers", "Chinese", "community"] },
      { name: "Appinn", description: "Chinese software discovery community for utilities, productivity tools, and small polished products.", url: "https://www.appinn.com/", country: "cn", tags: ["software discovery", "tools", "Chinese"] },
      { name: "Sspai", description: "High-quality Chinese productivity and digital-life media for long-form tutorials and product stories.", url: "https://sspai.com/", country: "cn", tags: ["productivity", "content", "media"] },
      { name: "Indie Hackers", description: "Indie builder community for sharing growth, revenue, experiments, and product lessons.", url: "https://www.indiehackers.com/", country: "us", tags: ["indie", "growth", "postmortem"] },
      { name: "Debut", description: "App discovery platform for polished apps, small tools, and design-driven products.", url: "https://debut.so/", country: "us", tags: ["apps", "discovery", "design"] },
    ],
  },
  {
    id: "payments-finance",
    title: "Payments / Global Finance",
    shortLabel: "Payments",
    summary: "Payments, subscriptions, tax handling, settlement, and company setup are often the real blockers for indie products.",
    items: [
      { name: "Stripe", description: "Mainstream payment and subscription infrastructure for SaaS, subscriptions, and global card payments.", url: "https://stripe.com/", country: "us", tags: ["payments", "subscriptions", "SaaS"] },
      { name: "Gumroad", description: "Digital product sales platform for courses, templates, ebooks, and small creator products.", url: "https://gumroad.com/", country: "us", tags: ["digital products", "courses", "sales"] },
      { name: "Creem", description: "Payment and tax-handling platform for software products, indie SaaS, and digital goods.", url: "https://www.creem.io/", country: "global", tags: ["payments", "tax", "SaaS"] },
      { name: "Payoneer", description: "Cross-border collection and settlement platform for overseas platform income and multi-currency money movement.", url: "https://www.payoneer.com/", country: "us", tags: ["cross-border", "settlement", "multi-currency"] },
      { name: "1st Formations", description: "UK company formation service for overseas entities, banking structure, and compliance foundations.", url: "https://www.1stformations.co.uk/", country: "uk", tags: ["company setup", "UK", "global"] },
    ],
  },
  {
    id: "github-free-resources",
    title: "GitHub Free Resources",
    shortLabel: "GitHub Free",
    summary: "One compact GitHub entry for free resources useful to AI builders, labeled by design, free courses, AI coding, local LLM/macOS, product marketing, and audio assets.",
    sections: [
      {
        title: "Design resources",
        summary: "Interface resources, design systems, DESIGN.md files, and visual rules that help AI coding stay visually consistent.",
        items: [
          { name: "awesome-design-md", description: "A collection of DESIGN.md files for popular brand design systems, useful for giving coding agents a concrete visual and component brief.", url: "https://github.com/VoltAgent/awesome-design-md", country: "global", tags: ["design resources", "DESIGN.md", "AI coding"], badge: "Design" },
          { name: "Design Resources for Developers", description: "Developer-friendly design resources covering colors, fonts, images, templates, CSS frameworks, UI libraries, and practical visual assets.", url: "https://github.com/bradtraversy/design-resources-for-developers", country: "global", tags: ["design resources", "frontend", "assets"], badge: "Design" },
          { name: "awesome-design-systems", description: "A curated collection of mature design systems and pattern libraries for studying components, content guidance, accessibility, and brand consistency.", url: "https://github.com/alexpate/awesome-design-systems", country: "global", tags: ["design resources", "design systems", "components"], badge: "Design" },
          { name: "Game-Assets-And-Resources", description: "A game asset and resource index covering 2D, 3D, mobile games, Unity, Steam, and other game-development contexts for fast prototyping.", url: "https://github.com/HotpotDesign/Game-Assets-And-Resources", country: "global", tags: ["game assets", "2D", "3D"], badge: "Game assets" },
          { name: "game-icons/icons", description: "The SVG icon repository for Game-icons.net, useful for RPG, card, strategy, inventory, skill, status, and game UI icons.", url: "https://github.com/game-icons/icons", country: "global", tags: ["game assets", "SVG icons", "UI"], badge: "Game assets" },
          { name: "GDQuest game-sprites", description: "CC0 game sprites from GDQuest for prototypes, useful when you want to focus on gameplay, collisions, movement, and level logic first.", url: "https://github.com/GDQuest/game-sprites", country: "global", tags: ["game assets", "sprites", "CC0"], badge: "Game assets" },
          { name: "Intersect Assets", description: "A complete 2D fantasy MMORPG asset collection with sprites, tilesets, animations, interface elements, sounds, music, and tools.", url: "https://github.com/AscensionGameDev/Intersect-Assets", country: "global", tags: ["game assets", "2D RPG", "tilesets"], badge: "Game assets" },
          { name: "Game Icon Pack", description: "A CC0 rounded game icon pack with SVG and multiple PNG sizes, useful for inventory, skills, items, buttons, and prototype UI.", url: "https://github.com/Nieobie/Game-Icon-Pack", country: "global", tags: ["game assets", "icon pack", "CC0"], badge: "Game assets" },
          { name: "awesome-cc0", description: "A CC0 public-domain resource index that includes Kenney, Quaternius, itch.io CC0, OpenGameArt, and other game-asset sources.", url: "https://github.com/madjin/awesome-cc0", country: "global", tags: ["game assets", "CC0", "asset index"], badge: "Game assets" },
        ],
      },
      {
        title: "Free courses",
        summary: "GitHub-hosted course paths and learning repos worth returning to for AI and LLM fundamentals.",
        items: [
          { name: "Neural Networks: Zero to Hero", description: "Andrej Karpathy's free neural-network course covering micrograd, makemore, GPT, tokenizers, and deep-learning foundations.", url: "https://github.com/karpathy/nn-zero-to-hero", country: "global", tags: ["free course", "deep learning", "Karpathy"], badge: "Course" },
          { name: "LLM Course", description: "Free LLM course path covering fundamentals, training, fine-tuning, deployment, and LLM application engineering.", url: "https://github.com/mlabonne/llm-course", country: "global", tags: ["free course", "LLM", "engineering"], badge: "Course" },
        ],
      },
      {
        title: "AI coding resources",
        summary: "Codex, Claude Code, MCP, code LLM, agent, and engineering-workflow resources.",
        items: [
          { name: "Hooosberg Starred", description: "My public GitHub starred list, used as a living candidate pool for AI coding, design, macOS, local models, and product-growth resources.", url: "https://github.com/hooosberg?tab=stars", country: "global", tags: ["AI coding", "watchlist", "curation"], badge: "Watchlist" },
          { name: "awesome-mcp-servers", description: "A large MCP server directory for finding data sources, tools, and automations that can connect to Codex, Claude Desktop, Cursor, Cline, and other agents.", url: "https://github.com/punkpeye/awesome-mcp-servers", country: "global", tags: ["AI coding", "MCP", "agents"], badge: "AI Coding" },
          { name: "Awesome-Code-LLM", description: "Papers, datasets, and benchmarks for code LLMs and software-engineering tasks, useful for understanding where AI coding actually works.", url: "https://github.com/codefuse-ai/awesome-code-llm", country: "global", tags: ["AI coding", "code LLM", "benchmarks"], badge: "AI Coding" },
          { name: "awesome-agents", description: "A directory of AI agent projects and frameworks, useful for comparing coding agents, execution tools, and orchestration approaches.", url: "https://github.com/kyrolabs/awesome-agents", country: "global", tags: ["AI coding", "agents", "open source"], badge: "AI Coding" },
          { name: "awesome-claude-code", description: "Claude Code skills, hooks, slash commands, orchestrators, applications, and plugins for building a richer terminal-agent workflow.", url: "https://github.com/hesreallyhim/awesome-claude-code", country: "global", tags: ["AI coding", "Claude Code", "workflow"], badge: "AI Coding" },
          { name: "agent-skills", description: "Production-grade engineering skills from Addy Osmani for turning clarification, testing, refactoring, review, and delivery into agent-readable workflows.", url: "https://github.com/addyosmani/agent-skills", country: "global", tags: ["AI coding", "skills", "quality gates"], badge: "AI Coding" },
        ],
      },
      {
        title: "Local LLM / macOS",
        summary: "Mac, SwiftUI, local-model, open-model, and offline AI product references.",
        items: [
