const getGroupItems = (group: ToolGroup) => group.items ?? group.sections?.flatMap((section) => section.items) ?? [];
const freeLearningItems = groups.find((group) => group.id === "free-learning")?.items ?? [];
const mergeFreeLearningIntoGitHubResources = (group: ToolGroup): ToolGroup => {
  if (group.id !== "github-free-resources") {
    return group;
  }

  return {
    ...group,
    sections: group.sections?.map((section) =>
      section.title === "Free courses"
        ? { ...section, items: [...section.items, ...freeLearningItems] }
        : section
    ),
  };
};
const githubResourcesGroup = groups.find((group) => group.id === "github-free-resources");
const directoryGroups = [
  ...(githubResourcesGroup ? [mergeFreeLearningIntoGitHubResources(githubResourcesGroup)] : []),
  ...groups.filter((group) => group.id !== "github-free-resources" && group.id !== "free-learning"),
];
const totalItems = directoryGroups.reduce((sum, group) => sum + getGroupItems(group).length, 0);
const emailLink = getLocalizedSocialLinks("en").find((link) => link.originalLabel === "Email");
const pageDescription = "A practical, searchable AI tool guide for builders: global AI assistants, coding agents, model APIs, product research, design tools, hosting, launch channels, payments, learning resources, and regional alternatives.";
const toolItems = directoryGroups.flatMap((group) =>
  getGroupItems(group).map((item) => ({
    name: item.name,
    url: item.url,
    description: `${group.title}: ${item.description}`,
  })),
);
const jsonLd = [
  buildSectionCollectionJsonLd({
    locale: "en",
    path: "/en/ai-navigation",
    name: "AI Tool Guide",
    description: pageDescription,
    topics: ["AI tools directory", "AI coding tools", "AI tool guide", "ChatGPT alternatives", "AI developer tools"],
  }),
  buildItemListJsonLd("https://hooosberg.com/en/ai-navigation#tool-list", toolItems),
];
---

<BaseLayout
  locale="en"
  title="AI Tool Guide | Hooosberg"
  description={pageDescription}
  canonicalPath="/en/ai-navigation"
  mainClass="main--ai-directory"
  jsonLd={jsonLd}
>
  <section class="ai-directory-hero">
    <div>
      <p class="hero-kicker">AI TOOL GUIDE</p>
      <h1>Choose tools by workflow, not hype.</h1>
      <p>
        This is not a generic link dump. It is a curated working map for builders:
        global default products, coding agents, model APIs, design and prototype tools,
        hosting, launch channels, payments, learning resources, and regional alternatives.
      </p>
      <label class="directory-search">
        <Search size={18} aria-hidden="true" />
        <input type="search" placeholder="Search tools, workflows, tags, or use cases" data-directory-search />
      </label>
      <div class="directory-stats" aria-label="Guide overview">
        <span>{groups.length} categories</span>
        <span>{totalItems} tools</span>
        <span>{alternativePairs.length} alternative maps</span>
        <span>Direct product links</span>
        <span>Editorial ranking</span>
      </div>
    </div>

    <div class="directory-method directory-contact-card" aria-label="Curation standard and submissions">
      <span class="directory-contact-card__eyebrow">TOOL DIRECTORY</span>
      <strong>Curation standard</strong>
      <p>
        Tools are included when they have a real product surface, practical workflow value,
        durable visibility, or direct relevance to the builds documented on this site.
        Announcement-only features are grouped under their parent product.
      </p>
      <a class="directory-contact-card__mail" href={emailLink?.url ?? "/en/links"}>
        <Mail size={18} aria-hidden="true" />
        <span>
          <small>Submit or contact</small>
          <b>{emailLink?.note ?? "zikedece@proton.me"}</b>
        </span>
      </a>
    </div>
  </section>

  <div class="directory-mode-toggle" role="tablist" aria-label="AI guide mode">
    <button class="is-active" type="button" role="tab" aria-selected="true" data-directory-mode="ranking">Workflow Rankings</button>
    <button type="button" role="tab" aria-selected="false" data-directory-mode="alternatives">Regional Alternatives</button>
  </div>

  <section class="ai-directory-shell" data-directory-shell data-mode="ranking" data-directory-current={directoryGroups[0].id} data-directory-filtered="false">
    <aside class="directory-sidebar" aria-label="AI guide categories">
      <button type="button" data-directory-filter="all">All rankings</button>
      {directoryGroups.map((group, index) => (
        <button
          class={index === 0 ? "is-active" : undefined}
          type="button"
          data-directory-filter={group.id}
          aria-current={index === 0 ? "true" : undefined}
        >
          {group.title}
        </button>
      ))}
    </aside>

    <div class="directory-content">
      <div data-directory-view="ranking">
        {directoryGroups.map((group) => (
          <section class="directory-group" id={group.id} data-directory-group={group.id}>
            <div class="directory-group__heading">
              <div>
                <p>{group.id}</p>
                <h2>{group.title}</h2>
              </div>
              <span>{group.summary}</span>
            </div>

            {group.sections ? (
              <div class="directory-subgroup-list">
                {group.sections.map((section) => (
                  <section class="directory-subgroup" aria-label={section.title}>
                    <div class="directory-subgroup__heading">
                      <h3>{section.title}</h3>
                      <p>{section.summary}</p>
                    </div>
                    <div class="directory-card-grid">
                      {section.items.map((item, index) => {
                        const rank = String(index + 1).padStart(2, "0");
                        const country = countryMeta[item.country];

                        return (
                          <a
                            class="directory-card"
                            href={item.url}
                            target="_blank"
                            rel="noreferrer"
                            data-directory-card
                            data-category={group.id}
                            data-search={`${group.title} ${group.shortLabel} ${section.title} ${country.name} ${country.access} ${item.name} ${item.description} ${item.tags.join(" ")}`}
                          >
                            <span class="directory-card__rank">TOP {rank}</span>
                            <span class="directory-card__icon">
                              {item.icon ? <img src={item.icon} alt="" loading="lazy" decoding="async" /> : item.name.slice(0, 1)}
                            </span>
                            <span class="directory-card__body">
                              <span class="directory-card__title-row">
                                <strong>{item.name}</strong>
                                {item.badge && <em>{item.badge}</em>}
                              </span>
                              <span class="directory-card__meta">
                                <span>{country.flag} {country.name}</span>
                                <span class={`directory-card__access directory-card__access--${country.tone}`}>{country.access}</span>
                              </span>
                              <p>{item.description}</p>
                              <span class="directory-card__tags">
                                {item.tags.map((tag) => <span>{tag}</span>)}
                              </span>
                            </span>
                            <ExternalLink class="directory-card__arrow" size={16} aria-hidden="true" />
                          </a>
                        );
                      })}
                    </div>
                  </section>
                ))}
              </div>
            ) : (
              <div class="directory-card-grid">
                {getGroupItems(group).map((item, index) => {
                  const rank = String(index + 1).padStart(2, "0");
                  const country = countryMeta[item.country];

                  return (
                    <a
                      class="directory-card"
                      href={item.url}
                      target="_blank"
                      rel="noreferrer"
                      data-directory-card
                      data-category={group.id}
                      data-search={`${group.title} ${group.shortLabel} ${country.name} ${country.access} ${item.name} ${item.description} ${item.tags.join(" ")}`}
                    >
                      <span class="directory-card__rank">TOP {rank}</span>
                      <span class="directory-card__icon">
                        {item.icon ? <img src={item.icon} alt="" loading="lazy" decoding="async" /> : item.name.slice(0, 1)}
                      </span>
                      <span class="directory-card__body">
                        <span class="directory-card__title-row">
                          <strong>{item.name}</strong>
                          {item.badge && <em>{item.badge}</em>}
                        </span>
                        <span class="directory-card__meta">
                          <span>{country.flag} {country.name}</span>
                          <span class={`directory-card__access directory-card__access--${country.tone}`}>{country.access}</span>
                        </span>
                        <p>{item.description}</p>
                        <span class="directory-card__tags">
                          {item.tags.map((tag) => <span>{tag}</span>)}
                        </span>
                      </span>
                      <ExternalLink class="directory-card__arrow" size={16} aria-hidden="true" />
                    </a>
                  );
                })}
              </div>
            )}

          </section>
        ))}

        <p class="directory-empty" data-directory-empty hidden>No matching tools. Try another keyword.</p>
      </div>

      <section id="alternatives" class="directory-alternatives" data-directory-view="alternatives" hidden>
        <div class="directory-group__heading directory-group__heading--full">
          <div>
            <p>alternatives</p>
            <h2>Regional alternatives</h2>
          </div>
          <span>
            The left side is the global reference product. The right side shows practical alternatives
            for Chinese-language or region-specific workflows. This is not one-to-one feature parity;
            it is a scenario map for getting work done.
          </span>
        </div>

        <div class="alternative-list">
          {alternativePairs.map((pair, index) => {
            const sourceCountry = countryMeta[pair.source.country];

            return (
              <article
                class="alternative-pair"
                data-alternative-card
                data-search={`${pair.category} ${pair.reason} ${pair.bestFor.join(" ")} ${pair.source.name} ${pair.source.description} ${pair.alternatives.map((item) => `${item.name} ${item.description} ${item.tags.join(" ")}`).join(" ")}`}
              >
                <div class="alternative-pair__source">
                  <span class="alternative-label">Global reference</span>
                  <a class="alternative-tool alternative-tool--source" href={pair.source.url} target="_blank" rel="noreferrer">
                    <span class="directory-card__rank">#{String(index + 1).padStart(2, "0")}</span>
                    <span class="directory-card__icon">
                      {pair.source.icon ? <img src={pair.source.icon} alt="" loading="lazy" decoding="async" /> : pair.source.name.slice(0, 1)}
                    </span>
                    <span>
                      <strong>{pair.source.name}</strong>
                      <small>{sourceCountry.flag} {sourceCountry.name} · {sourceCountry.access}</small>
                    </span>
                    <ExternalLink size={14} aria-hidden="true" />
                  </a>
                </div>

                <div class="alternative-pair__logic">
                  <span>{pair.category}</span>
                  <p>{pair.reason}</p>
                  <div>
                    {pair.bestFor.map((item) => <em>{item}</em>)}
                  </div>
                </div>

                <div class="alternative-pair__targets">
                  <span class="alternative-label">Practical alternatives</span>
                  <div>
                    {pair.alternatives.map((item) => {
                      const country = countryMeta[item.country];

                      return (
                        <a class="alternative-tool" href={item.url} target="_blank" rel="noreferrer">
                          <span class="directory-card__icon">
                            {item.icon ? <img src={item.icon} alt="" loading="lazy" decoding="async" /> : item.name.slice(0, 1)}
                          </span>
                          <span>
                            <strong>{item.name}</strong>
                            <small>{country.flag} {country.name} · {country.access}</small>
                          </span>
                          <ExternalLink size={14} aria-hidden="true" />
                        </a>
                      );
                    })}
                  </div>
                </div>
              </article>
            );
          })}
        </div>

        <p class="directory-empty" data-alternative-empty hidden>No matching alternative map. Try another keyword.</p>
      </section>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    const search = document.querySelector("[data-directory-search]");
    const filters = Array.from(document.querySelectorAll("[data-directory-filter]"));
    const cards = Array.from(document.querySelectorAll("[data-directory-card]"));
    const groups = Array.from(document.querySelectorAll("[data-directory-group]"));
    const empty = document.querySelector("[data-directory-empty]");
    const modeButtons = Array.from(document.querySelectorAll("[data-directory-mode]"));
    const views = Array.from(document.querySelectorAll("[data-directory-view]"));
    const shell = document.querySelector("[data-directory-shell]");
    const sidebar = document.querySelector(".directory-sidebar");
    const alternativeCards = Array.from(document.querySelectorAll("[data-alternative-card]"));
    const alternativeEmpty = document.querySelector("[data-alternative-empty]");
    const firstCategory = groups[0]?.dataset.directoryGroup || "top";
    let activeCategory = "all";
    let currentCategory = firstCategory;
    let activeMode = "ranking";

    const setCurrentCategory = (category, options = {}) => {
      currentCategory = category || firstCategory;
      if (shell) shell.dataset.directoryCurrent = currentCategory;

      filters.forEach((item) => {
        const isCurrent = item.dataset.directoryFilter === currentCategory;
        item.classList.toggle("is-active", isCurrent);
        if (isCurrent) {
          item.setAttribute("aria-current", "true");
        } else {
          item.removeAttribute("aria-current");
        }
      });

      const activeFilter = filters.find((item) => item.dataset.directoryFilter === currentCategory);
      if (options.scrollSidebar !== false && sidebar && activeFilter) {
        const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const behavior = reducedMotion ? "auto" : "smooth";

        if (sidebar.scrollWidth > sidebar.clientWidth) {
          sidebar.scrollTo({
            left: activeFilter.offsetLeft - (sidebar.clientWidth - activeFilter.clientWidth) / 2,
            behavior,
          });
        }

        if (sidebar.scrollHeight > sidebar.clientHeight) {
          sidebar.scrollTo({
            top: activeFilter.offsetTop - (sidebar.clientHeight - activeFilter.clientHeight) / 2,
            behavior,
          });
        }
      }
    };

    const syncShellFilteredState = () => {
      if (!shell) return;
      shell.dataset.directoryFiltered = activeMode === "ranking" && activeCategory !== "all" ? "true" : "false";
    };

    const updateRanking = () => {
      const query = (search?.value || "").trim().toLowerCase();
      let visibleCount = 0;

      cards.forEach((card) => {
        const category = card.dataset.category;
        const text = (card.dataset.search || "").toLowerCase();
        const visibleByCategory = activeCategory === "all" || category === activeCategory;
        const visibleByQuery = !query || text.includes(query);
        const visible = visibleByCategory && visibleByQuery;
        card.hidden = !visible;
        if (visible) visibleCount += 1;
      });

      groups.forEach((group) => {
        const hasVisibleCards = Array.from(group.querySelectorAll("[data-directory-card]")).some((card) => !card.hidden);
        group.hidden = !hasVisibleCards;
      });

      if (empty) empty.hidden = visibleCount !== 0;
    };

    const updateAlternatives = () => {
      const query = (search?.value || "").trim().toLowerCase();
      let visibleCount = 0;

      alternativeCards.forEach((card) => {
        const text = (card.dataset.search || "").toLowerCase();
        const visible = !query || text.includes(query);
        card.hidden = !visible;
        if (visible) visibleCount += 1;
      });

      if (alternativeEmpty) alternativeEmpty.hidden = visibleCount !== 0;
    };

    const update = () => {
      if (activeMode === "alternatives") {
        updateAlternatives();
        return;
      }

      updateRanking();
    };

    const scrollCategoryIntoView = (category) => {
      const targetCategory = category === "all" ? firstCategory : category;
      const target = groups.find((group) => group.dataset.directoryGroup === targetCategory) || groups[0];
      if (!target) return;

      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      window.requestAnimationFrame(() => {
        target.scrollIntoView({
          block: "start",
          behavior: reducedMotion ? "auto" : "smooth",
        });
      });
    };

    const setCategory = (category, options = {}) => {
      activeCategory = category || "all";
      syncShellFilteredState();
      if (search) search.value = "";
      updateRanking();
      setCurrentCategory(activeCategory === "all" ? firstCategory : activeCategory);
      if (options.scroll !== false) scrollCategoryIntoView(activeCategory);
    };

    const setMode = (mode) => {
      activeMode = mode;
      syncShellFilteredState();
      if (search) search.value = "";
      modeButtons.forEach((button) => {
        const active = button.dataset.directoryMode === mode;
        button.classList.toggle("is-active", active);
        button.setAttribute("aria-selected", active ? "true" : "false");
      });
      views.forEach((view) => {
        view.hidden = view.dataset.directoryView !== mode;
      });
      if (shell) shell.dataset.mode = mode;
      update();
    };

    filters.forEach((filter) => {
      filter.addEventListener("click", () => {
        setCategory(filter.dataset.directoryFilter || "all");
      });
    });

    modeButtons.forEach((button) => {
      button.addEventListener("click", () => setMode(button.dataset.directoryMode || "ranking"));
    });

    search?.addEventListener("input", update);

    if ("IntersectionObserver" in window) {
      const observer = new IntersectionObserver((entries) => {
        if (activeMode !== "ranking" || activeCategory !== "all") return;

        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            setCurrentCategory(entry.target.dataset.directoryGroup || firstCategory);
          }
        });
      }, { rootMargin: "-45% 0px -45% 0px", threshold: 0 });

      groups.forEach((group) => observer.observe(group));
    }

    const initialHash = window.location.hash.replace("#", "");
    if (initialHash === "alternatives") {
      setMode("alternatives");
    } else if (initialHash && groups.some((group) => group.dataset.directoryGroup === initialHash)) {
      setCategory(initialHash, { scroll: false });
    } else {
      syncShellFilteredState();
      setCurrentCategory(currentCategory, { scrollSidebar: false });
    }
  })();
</script>
