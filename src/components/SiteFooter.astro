---
import { brandNameByLocale, getLocalizedSocialLinks, uiText, type Locale } from "../utils/i18n";

type Props = {
  locale?: Locale;
};

const { locale = "zh-CN" } = Astro.props;
const text = uiText[locale];
const brandTitle = brandNameByLocale[locale];
const links = getLocalizedSocialLinks(locale);
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div>
      <strong>{brandTitle}</strong>
      <p>{text.footerCopy}</p>
    </div>
    <nav aria-label="Footer links">
      {links.map((link) => <a href={link.url} target={link.url.startsWith("http") ? "_blank" : undefined} rel="noreferrer">{link.label}</a>)}
    </nav>
  </div>
</footer>
