---
import type { ProductAction } from "../data/products";
import { getActionIcon } from "../utils/linkIcons";

type Props = {
  action: ProductAction;
  primary?: boolean;
  text?: boolean;
  class?: string;
};

const { action, primary = false, text = false, class: className = "" } = Astro.props;
const isDisabled = action.disabled || !action.url;
const isExternal = Boolean(action.url?.startsWith("http"));
const icon = action.icon ?? getActionIcon(action.label, action.url ?? "");
const classList = text
  ? ["text-action", "product-card__button", isDisabled && "text-action--disabled", className]
  : ["button", primary ? "button--primary" : "button--secondary", isDisabled && "button--disabled", className];
---

{isDisabled ? (
  <span class:list={classList} aria-disabled="true">
    <img class={text ? "action-icon" : "button-icon"} src={icon} alt="" loading="lazy" decoding="async" />
    {action.label}
  </span>
) : (
  <a class:list={classList} href={action.url} target={isExternal ? "_blank" : undefined} rel={isExternal ? "noreferrer" : undefined}>
    <img class={text ? "action-icon" : "button-icon"} src={icon} alt="" loading="lazy" decoding="async" />
    {action.label}
    <slot />
  </a>
)}
