---
import ProductIcon from "./ProductIcon.astro";
import type { Product } from "../data/products";

type Props = {
  product: Product;
};

const { product } = Astro.props;
const isSumiMahjong = product.slug === "sumi-mahjong";
const updatedDate = product.slug === "sumi-mahjong" || product.slug === "mood-button" ? "2026-06-26" : "2026-06-19";
const scopeText = product.hideSourceLinks
  ? "The product page, App Store download link, privacy policy, terms, and support contact define the current public product scope."
  : "The product page, download link, source repository, and support contact define the current public product scope.";
const purchasesText = product.hideSourceLinks
  ? "Downloads, purchases, in-app purchases, refunds, updates, and account-level store records are handled by Apple App Store and Apple StoreKit."
  : "Downloads, purchases, subscriptions, in-app purchases, refunds, updates, and account-level store records may be handled by the platform linked from the product page, such as Apple App Store, Chrome Web Store, GitHub Releases, or another distribution channel.";
const thirdPartyText = product.hideSourceLinks
  ? "The app may use Apple platform services such as App Store, StoreKit, and iCloud/iOS system behavior where applicable. Apple's own terms and policies apply to those services."
  : "Some workflows may involve third-party systems selected by you, such as model APIs, app stores, browser accounts, GitHub, or cloud services. Their own terms and policies apply to those services.";
---

<article class="article-detail legal-document" style={`--accent:${product.accent}`}>
  <header>
    <ProductIcon product={product} size="lg" />
    <p>{product.category} / Last updated {updatedDate}</p>
    <h1>{product.displayName} Terms of Service</h1>
    <div class="tag-row">
      <span>{product.status.join(" / ")}</span>
      <span>{product.platforms.join(" / ")}</span>
    </div>
  </header>

  <div class="legal-body">
    <section>
      <h2>Product Scope</h2>
      <p>{product.displayName} is provided as {product.tagline}</p>
      <p>{scopeText}</p>
    </section>

    <section>
      <h2>Use of the Product</h2>
      {isSumiMahjong ? (
        <p>Sumi Mahjong is a casual tile matching game. Do not misuse the app, reverse engineer it, extract or redistribute its artwork, audio, icons, screenshots, code, or other bundled assets, or use it in ways that violate applicable law, platform rules, or third-party rights.</p>
      ) : (
        <p>You are responsible for how you use the product, the files or content you import, and any output you create with it. Do not use the product in ways that violate applicable law, platform rules, or third-party rights.</p>
      )}
    </section>

    <section>
      <h2>User Content and Local Data</h2>
      <p>{product.privacy.note}</p>
      {isSumiMahjong ? (
        <p>Game progress, best times, settings, and local theme unlock state are stored on the device. You are responsible for your device security, backups, and iOS settings. Deleting the app may remove local app data according to iOS behavior.</p>
      ) : (
        <p>When the product works with local files, local browser sessions, local app data, or local models, you remain responsible for maintaining your own backups and device security.</p>
      )}
    </section>

    <section>
      <h2>Downloads, Purchases, and Updates</h2>
      <p>{purchasesText}</p>
      {isSumiMahjong && (
        <p>The core game is playable for free. The optional non-consumable in-app purchase Unlock All Themes unlocks premium visual themes through Apple StoreKit. Sumi Mahjong does not offer auto-renewable subscriptions. Refunds, billing issues, and purchase records are handled by Apple under App Store rules.</p>
      )}
    </section>

    <section>
      <h2>Third-Party Services</h2>
      <p>{thirdPartyText}</p>
      {isSumiMahjong && (
        <p>Sumi Mahjong does not include advertising networks, third-party analytics SDKs, social feeds, cloud saves, or third-party AI services. Some bundled art or audio may include licensed or credited materials; those materials remain subject to their respective rights and may not be extracted or reused outside the app.</p>
      )}
    </section>

    <section>
      <h2>Support and Changes</h2>
      <p>For support, contact <a href="mailto:zikedece@proton.me">zikedece@proton.me</a> or Telegram <a href="https://t.me/hooosberg" target="_blank" rel="noreferrer">@hooosberg</a>. These terms may be updated when product features, pricing, distribution, or legal requirements change.</p>
    </section>
  </div>
</article>
